# Copia questo file in ".env" (che NON va mai committato in git — aggiungilo
# a .gitignore) e compila i valori veri. In produzione preferisci settare
# queste variabili a livello di sistema/servizio invece di un file su disco.
#
# NOTA IMPORTANTE: se la password del DB "cresla_dev" e' quella che era
# scritta in chiaro nello script originale, VA RUOTATA: e' stata condivisa
# in chiaro ed e' quindi da considerare compromessa.

# ---- DATABASE ----
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_POOL_SIZE=8

# ---- FILE PATH ----
RAW_FILE=/srv/python-projects/gene-environment/output_combined_scolarita.csv
ENV_FILE=/srv/python-projects/gene-environment/data/componenti_ambientali_full.csv
TEMP_DF_PATH=/srv/python-projects/gene-environment/temp_df.pkl

GENERATION=2
TEST=0_1

# ---- DATA SETTINGS ----
SEP=,
DECIMAL=.
TARGET_COL=onset_age
EXPOSURE=education_years
COVARIATES=sex,onset_site,diagnostic_delay
SAMPLE_ID_COL=id

# ---- MATCHING ----
MATCH_K=3
MIN_TREATED=5
MIN_SAMPLE_SIZE=10
MAX_SMD=0.25

# ---- PERMUTATION ----
N_PERM=100
N_PERM_HIGH=1000
RANDOM_STATE=42
MIN_OBS_COEF=2
PVALUE_THRESHOLD=0.05
ADAPTIVE_PERM_CHECK_EVERY=100
ADAPTIVE_PERM_FUTILITY_P=0.5

# ---- SCALING / PARALLEL ----
STANDARDIZE=true
MAX_WORKERS=16

# ---- ONSET AGE ----
USE_MANN_WHITNEY=true
ONSET_ALPHA=0.05
ONSET_MIN_GROUP_SIZE=5
ONSET_LOW_POWER_THRESHOLD=10
N_BOOT=2000

# ---- GENE REDUCTION / VCF FILTERING ----
VCF_DIR_GEN1=/mnt/cresla_prod/genome_datasets/gen1
VCF_DIR_GEN2=/mnt/cresla_prod/genome_datasets/gen2
VCF_DIR_GEN3=/mnt/cresla_prod/genome_datasets/gen3
ENV_GENERATION_COL=
VCF_FOLDERS=/mnt/cresla_prod/genome_datasets/gen2,/mnt/cresla_prod/genome_datasets/gen3
NULL_PERCENTAGE=0.30
OUTPUT_FOLDER=/mnt/cresla_prod/genome_datasets/merged_csv
MAF_THRESHOLD=0.001
LD_WINDOW_SIZE=50
LD_STEP=5
LD_R2_THRESHOLD=0.8

# ---- VCF sorgenti indicizzati per generazione (extract-significant) ----
VCF_DIR_GEN1=/mnt/cresla_prod/genome_datasets/gen1
VCF_DIR_GEN2=/mnt/cresla_prod/genome_datasets/gen2
VCF_DIR_GEN3=/mnt/cresla_prod/genome_datasets/gen3

USE_PCA_COVARIATES=true
PCA_N_COMPONENTS=5
PCA_COVARIATES_PATH_TEMPLATE=/mnt/cresla_prod/genome_datasets/qc_output_gen{generation}/pca_covariates.csv

# ---- OUTPUT ----
SIGNIFICANT_MATRIX_DIR=/srv/python-projects/gene-environment/significant_variant_matrices
SIGNIFICANT_EXPORT_DIR=/srv/python-projects/gene-environment/significant_export
ONSET_AGE_OUT_DIR=/srv/python-projects/gene-environment/onset_age_analysis
LOG_DIR=/srv/python-projects/gene-environment/logs


# ---- vQTL: esposizioni testate (Step 5/6/7) ----
# Se vuoto, di default = [EXPOSURE]. Nel run originale erano 3, testate
# separatamente:
VQTL_EXPOSURES=seminativi_1000,risaie_1000,vigneti_1000,seminativi_1500,risaie_1500,vigneti_1500

# ---- vQTL: covariate di correzione ----
# Se vuoto, di default = COVARIATES (le stesse del resto della pipeline).
# Imposta questa variabile per usare un elenco diverso SOLO per vqtl, senza
# toccare COVARIATES (usata anche da gene_environment). Esempio: per
# escludere onset_site solo da vqtl:
VQTL_COVARIATES=sex,diagnostic_delay

# ---- vQTL: scan genome-wide (Step 3, QUAIL-style) ----
VQTL_TAUS=0.05,0.10,0.15,0.20,0.25,0.30,0.35,0.40,0.45
VQTL_SE_METHOD=asymptotic
VQTL_BOOTSTRAP_K=200
VQTL_CHUNK_SIZE=2000
# 0 = usa MAX_WORKERS (default consigliato, un solo numero da tenere sincronizzato)
VQTL_N_JOBS=0
# Rete di sicurezza opzionale: lascia 0 se RAW_FILE e' gia' filtrato MAF/LD a
# monte (come nel .env fornito: MAF_THRESHOLD/LD_* sono gia' applicati da
# `gene_environment.cli filter-vcf`).
VQTL_MIN_MAF=0.0
VQTL_MIN_CALL_RATE=0.0

# ---- vQTL: filtro candidati (Step 4) ----
VQTL_FILTER_P_COLUMN=P_gc
VQTL_FILTER_P_THRESHOLD=1e-5
# lascia vuoto per usare la soglia sopra; imposta un intero per prendere i
# top N candidati indipendentemente dalla soglia
VQTL_FILTER_TOP_N=

# ---- vQTL: interazione / rGE / eteroschedasticita' (Step 5/6) ----
VQTL_ROBUST_SE=true
VQTL_RGE_HET_ALPHA=0.05
# soglia (nominale, non corretta per test multipli) per popolare
# vqtl_interaction_results_significant
VQTL_INTERACTION_SIG_THRESHOLD=0.05

# ---- vQTL: permutazioni Freedman-Lane (Step 7) ----
# 0 = usa N_PERM_HIGH
VQTL_N_PERM=0
VQTL_PERM_TOP_N_LOCI=10

# ---- vQTL: output ----
VQTL_RESULTS_DIR=/srv/python-projects/gene_environment_v2/vqtl_results



# ---- GENetLib: cromosomi e generazioni ----
# Vuoto = tutti i cromosomi 1..22 (gene_environment.vcf_pipeline.vcf_to_parquet.CHROMOSOMES)
GXE_CHROMOSOMES=
# Vuoto = usa solo GENERATION (comportamento identico al resto della pipeline,
# una generazione per run). "1,2" = analisi congiunta delle due coorti
# (residui PCA calcolati per generazione, poi combinati in un unico modello
# GENetLib per cromosoma).
GXE_GENERATIONS=

# ---- GENetLib: iperparametri scalar_ge ----
# Corrispondenza con i concetti "lam"/"alpha"/"max_iter":
#   lam   -> GXE_LAMBDA2 (penalita' MCP) e GXE_LAMBDA_L2 (penalita' L2)
#   alpha -> non esiste un alpha singolo: due learning rate distinti
#            (GXE_LEARNING_RATE1 per i layer sparsi G/GxE, GXE_LEARNING_RATE2
#            per i layer nascosti)
#   max_iter -> GXE_NUM_EPOCHS
GXE_NUM_HIDDEN_LAYERS=2
GXE_NODES_HIDDEN_LAYER=64,16
GXE_NUM_EPOCHS=100
GXE_LEARNING_RATE1=0.02
GXE_LEARNING_RATE2=0.01
GXE_LAMBDA1=
GXE_LAMBDA2=0.05
GXE_LAMBDA_L2=0.05
GXE_SPLIT_TYPE=0
GXE_RATIO=7,3

# Soglia di significativita': frazione (0-1) del massimo |peso| assoluto del
# layer sparso (convenzione nativa di GENetLib, NON un p-value)
GXE_SIGNIFICANCE_THRESHOLD=0.3

# Numero minimo di pazienti richiesti per processare un cromosoma
GXE_MIN_SAMPLES=30

# ---- Output ----
GXE_OUTPUT_DIR=/srv/python-projects/gene_environment_v2/output/gxe_genetlib
GXE_SAVE_PLOTS=true
GXE_SAVE_WORD_SUMMARY=true
GXE_TORCH_THREADS=1
